<!DOCTYPE html>
<html>
<head>
    <title>Student Management</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <h2>Student List</h2>

    <!-- Add Student Button -->
    <div class="add-btn">
        <a href="/add" class="btn">Add Student</a>
    </div>

    <!-- Student Table -->
    <div class="table-container">
        <table>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Email</th>
                <th>Course</th>
                <th>Actions</th>
            </tr>

            <% students.forEach(student => { %>
                <tr>
                    <td><%= student.id %></td>
                    <td><%= student.name %></td>
                    <td><%= student.email %></td>
                    <td><%= student.course %></td>
                    <td>
                        <a href="/edit/<%= student.id %>">Edit</a>
                        <a href="/delete/<%= student.id %>">Delete</a>
                    </td>
                </tr>
            <% }) %>
        </table>
    </div>

</body>
</html>